# Copia este archivo como .env en el VPS y completa los valores.
# El .env NUNCA se sube a git (esta ignorado en .gitignore).

# Password de Postgres. Genera uno aleatorio, por ejemplo:  openssl rand -hex 24
POSTGRES_PASSWORD=

# API key de Anthropic. Se inyecta directo en el VPS, nunca por el chat.
ANTHROPIC_API_KEY=
